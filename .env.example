# Server
PORT=8080
DATA_DIR=./data
LOG_LEVEL=info

# Defaults
SUMMARIZE_ENGINE=pi
SUMMARIZE_PROMPT="Summarize the following content clearly and accurately. Include a concise overview, key points, and action items if any."

# Engines
SUMMARIZE_PI_BIN=pi
SUMMARIZE_AGY_BIN=agy
SUMMARIZE_PI_MODEL=
SUMMARIZE_AGY_MODEL=
SUMMARIZE_RUN_TIMEOUT=15m
SUMMARIZE_MAX_INPUT_CHARS=100000

# YouTube
SUMMARIZE_YTDLP_BIN=yt-dlp
SUMMARIZE_TRANSCRIPT_LANGS=en.*,en
SUMMARIZE_YTDLP_TIMEOUT=60s

# NATS
NATS_HOST=127.0.0.1
NATS_PORT=-1
NATS_SUBJECT_SUMMARY_REQUESTED=summaries.requested
