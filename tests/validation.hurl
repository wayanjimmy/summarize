# Input validation tests
# All requests should return 400 with structured error responses.

# 1. Empty body (no JSON payload)
POST {{HOST}}/v1/summaries
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "invalid JSON body"

# 2. Empty JSON object — neither url nor text
POST {{HOST}}/v1/summaries
{}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "exactly one of url or text is required"

# 3. Both url and text provided — must be exactly one
POST {{HOST}}/v1/summaries
{
  "url": "https://youtu.be/abc123",
  "text": "some text"
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "exactly one of url or text is required"

# 4. Empty string text — both fields empty, hits "exactly one" check first
POST {{HOST}}/v1/summaries
{
  "text": ""
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "exactly one of url or text is required"

# 5. Whitespace-only text (trimmed to empty)
POST {{HOST}}/v1/summaries
{
  "text": "   "
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "text must be non-empty"

# 6. Non-YouTube URL
POST {{HOST}}/v1/summaries
{
  "url": "https://example.com"
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "url must be a valid YouTube URL"

# 7. Invalid engine name
POST {{HOST}}/v1/summaries
{
  "text": "some valid text",
  "engine": "gpt"
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "engine must be 'pi' or 'agy'"

# 8. Prompt exceeds maximum length (20001 chars)
POST {{HOST}}/v1/summaries
{
  "text": "some valid text",
  "prompt": ""
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "prompt too long (max 20000 chars)"

# 9. Boolean value for engine field — triggers JSON decode error
POST {{HOST}}/v1/summaries
{
  "text": "some valid text",
  "engine": true
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "invalid JSON body"

# 10. Number value for url field — triggers JSON decode error
POST {{HOST}}/v1/summaries
{
  "url": 12345
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
jsonpath "$.error.message" == "invalid JSON body"

# 11. Invalid model name
POST {{HOST}}/v1/summaries
{
  "text": "some valid text",
  "engine": "pi",
  "model": "definitely-not-a-real-model"
}
HTTP 400
[Asserts]
jsonpath "$.error.code" == "invalid_request"
